# Shared auth database (users, sessions metadata) from solaeyn.com
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/solaeyn

# Builder data database (batch scripts). Falls back to DATABASE_URL when empty.
BATCH_DATABASE_URL=postgresql://postgres:postgres@localhost:5432/solaeyn

# Same Redis instance used by solaeyn.com sessions.
REDIS_URL=redis://localhost:6379

# Optional override. Default behavior redirects to the apex domain (for example https://solaeyn.com).
AUTH_LOGIN_URL=

# CSRF signing secret. A random ephemeral key is used when empty (not recommended in production).
CSRF_SECRET=

# Cookie domain override. Derived from the request host when empty.
SESSION_COOKIE_DOMAIN=

# PostgreSQL SSL mode. Use disable for Coolify/internal PostgreSQL.
DATABASE_SSL_MODE=disable

PORT=3020
NODE_ENV=development
