{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "Bundler",
    "moduleDetection": "force",
    "lib": ["ES2022", "DOM"],
    "allowJs": false,
    "checkJs": false,
    "allowImportingTsExtensions": true,
    "resolveJsonModule": true,
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": false,
    "noEmit": true,
    "types": ["node", "vitest/globals"],
    "jsx": "preserve"
  },
  "include": ["src/**/*.ts", "public/**/*.tsx", "tests/**/*.ts", "vitest.config.ts", "scripts/**/*.mjs", "scripts/**/*.ts"]
}
